APP_IMAGE=ghcr.io/owner/repository:latest
APP_ENV_FILE=env/.env.prod.example
APP_PORT=8080

POSTGRES_DB=post
POSTGRES_USER=post
POSTGRES_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/post
SPRING_DATASOURCE_USERNAME=post
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_JPA_HIBERNATE_DDL_AUTO=update

SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

JWT_ACCESS_TOKEN_SECRET=replace-with-base64-encoded-256-bit-secret
JWT_ACCESS_TOKEN_EXPIRATION_TIME=900
JWT_REFRESH_TOKEN_SECRET=replace-with-base64-encoded-256-bit-secret
JWT_REFRESH_TOKEN_EXPIRATION_TIME=1209600
